# A deployable fridge: right-click at the floor spot to install. Uses the
# same used:carrot_on_a_stick trigger as the Stirring Rod.
give @s minecraft:carrot_on_a_stick[custom_name={text:"Fridge Kit",color:"aqua",italic:false},lore=[{text:"Right-click while looking at the floor",color:"gray",italic:false},{text:"to install the fridge there.",color:"gray",italic:false}],custom_data={lab_place:"fridge"},custom_model_data={strings:["lab_fridge_kit"]},max_stack_size=1]
