# Scratch objective (#steps/#found/#done/#total/#t20/#t40 + per-symbol #c_* counts)
scoreboard objectives add lab.var dummy
# Stirring Rod right-click detection (same trick as the Flashlights datapack)
scoreboard objectives add lab.rod used:carrot_on_a_stick
# Per-player reaction counter (drives the Chemist experiment)
scoreboard objectives add lab.rxn dummy
# Fridge identity: each fridge interaction entity gets a unique id (#next_id counter)
scoreboard objectives add lab.id dummy
# Hazard timers on item entities (gas escape / phosphorus ignition)
scoreboard objectives add lab.age dummy
# SCP-009 infection progression per player (any contact starts it)
scoreboard objectives add lab.inf dummy
# SCP-207 progression timer per player
scoreboard objectives add lab.cola dummy
# SCP-008 infection timer per player
scoreboard objectives add lab.z008 dummy
# "I shouldn't drink this" message cooldown per player
scoreboard objectives add lab.sip dummy
# Version handshake: the labra-plugin refuses its datapack-backed commands
# (with a clear message) when this marker is missing or too old, instead of
# dispatching functions that silently don't exist.
scoreboard players set #datapack lab.var 25

