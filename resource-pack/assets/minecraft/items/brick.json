{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "lab_medkit",
        "model": {
          "type": "minecraft:model",
          "model": "lab:item/lab_medkit"
        }
      },
      {
        "when": "lab_extinguisher",
        "model": {
          "type": "minecraft:model",
          "model": "lab:item/lab_extinguisher"
        }
      },
      {
        "when": "lab_extinguisher_mount",
        "model": {
          "type": "minecraft:model",
          "model": "lab:item/lab_extinguisher_mount"
        }
      },
      {
        "when": "lab_sprinkler_button",
        "model": {
          "type": "minecraft:model",
          "model": "lab:item/lab_sprinkler_button"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/brick"
    }
  }
}